---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About — ${SITE_TITLE}`} description="Learn about CMMR LLC, a consulting and project incubation firm." />
	</head>
	<body>
		<Header />
		<main>
			<section class="about-hero">
				<h1>About CMMR LLC</h1>
			</section>

			<section class="about-content">
				<p>
					CMMR LLC is a consulting and project incubation firm focused on helping founders,
					startups, and organizations bring bold ideas to life. We combine deep technical
					expertise with practical business strategy to move projects from napkin sketch to
					production.
				</p>
				<p>
					Whether it's standing up a new product, advising on architecture and engineering
					practices, or providing fractional technical leadership, CMMR operates as an
					embedded partner — not an outside vendor.
				</p>

				<h2>How We Work</h2>
				<p>
					We keep things lean and focused. Engagements are structured around clear outcomes:
					validated prototypes, shipping products, or strategic roadmaps. We believe in short
					feedback loops, honest assessments, and building things that actually work.
				</p>

				<h2>Background</h2>
				<p>
					CMMR was founded to create a vehicle for consulting work and early-stage project
					incubation. We draw on years of experience across software engineering, cloud
					infrastructure, and product development to help our partners move faster and make
					better decisions.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.about-hero {
		text-align: center;
		padding: 3rem 0 1.5rem;
	}
	.about-hero h1 {
		font-size: 2.8rem;
	}
	.about-content {
		max-width: 640px;
		margin: 0 auto;
	}
	.about-content h2 {
		margin-top: 2rem;
	}
	.about-content p {
		line-height: 1.8;
	}
</style>
