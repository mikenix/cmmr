---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About — ${SITE_TITLE}`} description="Learn about CMMR LLC, a consulting and project incubation firm." />
	</head>
	<body>
		<Header />
		<main>
			<section class="about-hero reveal">
				<p class="kicker">About</p>
				<h1>CMMR is where consulting discipline meets incubation speed.</h1>
				<p>
					We partner with teams that need both strategic clarity and practical execution,
					especially when product complexity is high and time matters.
				</p>
			</section>

			<section class="about-grid reveal" style="--d: 0.08s">
				<article>
					<h2>What We Solve</h2>
					<p>
						CMMR helps founders and organizations move from ambiguous opportunity to clear,
						testable product direction. We support technical due diligence, architecture,
						roadmapping, and the first phases of execution.
					</p>
				</article>
				<article>
					<h2>How We Operate</h2>
					<p>
						We work as an embedded partner. That means transparent prioritization, short
						feedback cycles, and decisions grounded in business impact rather than novelty.
					</p>
				</article>
				<article>
					<h2>Where We Add Leverage</h2>
					<p>
						Our sweet spot is early-stage or transition-stage teams: new product lines,
						stalled deliveries, scaling pains, and moments where technical leadership is
						the bottleneck.
					</p>
				</article>
			</section>

			<section class="principles reveal" style="--d: 0.12s">
				<h2>Operating Principles</h2>
				<ul>
					<li>Execution over theater.</li>
					<li>Small, reversible bets before big commitments.</li>
					<li>Architecture in service of outcomes.</li>
					<li>Documentation that makes teams faster.</li>
				</ul>
			</section>

			<section class="fit reveal" style="--d: 0.16s">
				<h2>Good Fit Engagements</h2>
				<p>
					If you need to validate a product idea, untangle technical complexity, or install
					senior technical leadership while your team scales, CMMR is built for that.
				</p>
				<a href="mailto:hello@cmmr.com">Contact CMMR</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.about-hero {
		padding: 1rem 0 0.75rem;
		max-width: 820px;
		margin: 0 auto;
	}
	.kicker {
		margin: 0;
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent-dark);
	}
	.about-hero h1 {
		font-size: clamp(2rem, 4vw, 3rem);
		margin: 0.3rem 0 0.5rem;
	}
	.about-hero p {
		margin: 0;
		font-size: 1.08rem;
		color: rgb(var(--muted));
	}
	.about-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1.8rem;
	}
	.about-grid article {
		padding: 1.2rem;
		border-radius: var(--radius-md);
		border: 1px solid rgba(var(--line), 1);
		background: rgba(255, 255, 255, 0.82);
		box-shadow: 0 10px 22px rgba(6, 32, 51, 0.07);
	}
	.about-grid h2 {
		font-size: 1.25rem;
		margin-bottom: 0.45rem;
	}
	.about-grid p {
		margin: 0;
		font-size: 0.98rem;
		color: rgb(var(--muted));
	}
	.principles {
		margin-top: 1.8rem;
		padding: 1.2rem;
		border-radius: var(--radius-md);
		border: 1px solid rgba(var(--line), 1);
		background: rgba(var(--surface), 0.7);
	}
	.principles h2 {
		margin-bottom: 0.6rem;
	}
	.principles ul {
		margin: 0;
		padding-left: 1.1rem;
	}
	.principles li {
		margin: 0.35rem 0;
	}
	.fit {
		margin-top: 1.8rem;
		padding: 1.4rem;
		text-align: center;
		border-radius: var(--radius-lg);
		border: 1px solid rgba(var(--line), 1);
		background: rgba(15, 118, 110, 0.08);
	}
	.fit p {
		margin: 0.25rem auto 0.9rem;
		max-width: 58ch;
		color: rgb(var(--muted));
	}
	.fit a {
		display: inline-block;
		padding: 0.7rem 1rem;
		background: var(--accent);
		color: #fff;
		border-radius: 999px;
		font-weight: 700;
		text-decoration: none;
	}
	.fit a:hover {
		background: var(--accent-dark);
		color: #fff;
	}
	.reveal {
		opacity: 0;
		transform: translateY(14px);
		animation: rise 0.6s ease forwards;
		animation-delay: var(--d, 0s);
	}
	@keyframes rise {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
	@media (max-width: 720px) {
		.about-grid {
			grid-template-columns: 1fr;
		}
		.about-grid article,
		.principles,
		.fit {
			padding: 1rem;
		}
	}
</style>
