---
const today = new Date();
---

<footer>
	<div class="footer-main">
		<p class="brand">CMMR LLC</p>
		<p class="tag">Consulting and project incubation for serious builders.</p>
		<p class="meta">&copy; {today.getFullYear()} CMMR LLC. All rights reserved.</p>
	</div>
	<div class="social-links">
		<a href="https://github.com/mikenix" target="_blank">
			<span class="sr-only">CMMR on GitHub</span>
			<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32" astro-icon="social/github"
				><path
					fill="currentColor"
					d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
				></path></svg
			>
			<span>GitHub</span>
		</a>
	</div>
</footer>
<style>
	footer {
		padding: 3.2em 1em 3.8em;
		margin-top: 2rem;
		border-top: 1px solid rgba(var(--line), 0.95);
		background:
			radial-gradient(90% 120% at 10% 10%, rgba(15, 118, 110, 0.16) 0%, rgba(15, 118, 110, 0) 55%),
			linear-gradient(180deg, #eef6f5 0%, #f7f9fb 100%);
		text-align: center;
	}
	.footer-main {
		margin: 0 auto;
		max-width: 680px;
	}
	.brand {
		margin: 0;
		font-size: 1.1rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgb(var(--ink));
	}
	.tag {
		margin: 0.35em 0;
		color: rgb(var(--muted));
	}
	.meta {
		margin: 0;
		font-size: 0.92rem;
		color: rgb(var(--muted));
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 0.75em;
		margin-top: 1.2em;
	}
	.social-links a {
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.5em 0.8em;
		border-radius: 999px;
		border: 1px solid rgba(var(--line), 0.95);
		color: rgb(var(--ink));
	}
	.social-links a:hover {
		color: var(--accent-dark);
		border-color: var(--accent);
	}
	.social-links svg {
		width: 18px;
		height: 18px;
	}
</style>
